generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model Product {
  id            String   @id @default(cuid())
  name          String
  material      String?
  category      String
  scale         String?
  badge         String?
  price         Int
  stock         Int
  year          Float?
  colorPattern  String?  @map("color_pattern")
  imageUrl      String?  @map("image_url")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("products")
}